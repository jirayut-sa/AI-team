                </div>
            </div>

            <!-- Team Assignment Status -->
            <div id="teamAssignmentPanel" class="glass-panel rounded-3xl p-6 hidden animate-fade-in relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-brand-500/5 rounded-full blur-2xl"></div>
                
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-network-wired text-brand-500"></i> ทีมปฏิบัติการที่ได้รับมอบหมาย
                </h3>

                <div class="space-y-3">
                    <div class="flex items-center gap-4 p-4 bg-white border border-brand-100 rounded-2xl shadow-sm relative overflow-hidden">
                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-brand-500"></div>
                        <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center text-brand-600 text-xl border border-brand-100">
                            <i class='bx bxs-brain'></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs font-bold text-brand-600 mb-0.5">LEAD AGENT (ผู้ทำงานหลัก)</p>
                            <h4 id="leadName" class="text-base font-bold text-slate-800"></h4>
                            <p id="leadRole" class="text-xs text-slate-500 truncate max-w-[200px]"></p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 p-4 bg-white border border-accent-100 rounded-2xl shadow-sm relative overflow-hidden">
                         <div class="absolute left-0 top-0 bottom-0 w-1 bg-accent-500"></div>
                        <div class="w-12 h-12 rounded-full bg-accent-50 flex items-center justify-center text-accent-600 text-xl border border-accent-100">
                            <i class='bx bx-check-shield'></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs font-bold text-accent-600 mb-0.5">REVIEWER (ผู้ช่วยตรวจสอบ)</p>
                            <h4 id="reviewerName" class="text-base font-bold text-slate-800"></h4>
                            <p id="reviewerRole" class="text-xs text-slate-500 truncate max-w-[200px]"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Prompt Engineering (7 cols) -->
        <div class="lg:col-span-7 space-y-6">
            
            <div class="glass-panel rounded-3xl p-6 md:p-8 flex flex-col h-full min-h-[550px] relative">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-slate-500 text-sm">2</span>
                        เขียนบรีฟงานเบื้องต้น (Brief)
                    </h3>
                </div>

                <!-- Input Area -->
                <div class="relative group mb-6">
                    <textarea id="promptInput" rows="4" class="w-full bg-white border-2 border-slate-200 rounded-2xl p-4 text-slate-700 focus:outline-none focus:border-brand-500 transition-all resize-none shadow-inner text-sm md:text-base placeholder-slate-400" placeholder="พิมพ์สิ่งที่คุณต้องการให้ AI ทำสั้นๆ หรือตามสไตล์ของคุณ ระบบจะนำไปแปลงเป็นคำสั่งระดับมืออาชีพให้อัตโนมัติ..."></textarea>
                </div>

                <!-- Refined Prompt Area (Auto-Generated) -->
                <div class="flex-grow flex flex-col mb-6 relative">
                    <label class="flex justify-between items-end text-xs font-bold text-brand-600 uppercase tracking-wide mb-2 pl-1">
                        <span><i class="fa-solid fa-wand-magic-sparkles mr-1"></i> คำสั่งฉบับสมบูรณ์ (Auto-Generated Prompt)</span>
                    </label>
                    
                    <div class="relative flex-grow h-64">
                        <textarea id="refinedPrompt" class="absolute inset-0 w-full h-full bg-brand-50/30 border-2 border-slate-100 rounded-2xl p-4 text-slate-600 focus:outline-none transition-all resize-none text-sm font-mono leading-relaxed" readonly placeholder="คำสั่งระดับ Pro จะปรากฏที่นี่หลังจากกดปุ่มส่งงาน..."></textarea>
                        
                        <!-- Overlay Loading State -->
                        <div id="promptLoader" class="loader-overlay">
                            <div class="w-16 h-16 relative flex items-center justify-center mb-4">
                                <div class="absolute inset-0 border-4 border-slate-200 rounded-full"></div>
                                <div class="absolute inset-0 border-4 border-brand-500 rounded-full border-t-transparent animate-spin"></div>
                                <i class="fa-solid fa-robot text-brand-500 text-xl animate-pulse"></i>
                            </div>
                            <h4 id="loaderStatusTitle" class="text-brand-600 font-bold text-lg mb-1">AI Prompt Engineer กำลังทำงาน</h4>
                            <p id="loaderStatusText" class="text-slate-500 text-sm animate-pulse-fast">กำลังวิเคราะห์ความต้องการและปรับแต่งโครงสร้าง...</p>
                        </div>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="mt-auto">
                    <button onclick="processAndSend()" id="submitBtn" class="w-full bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-700 hover:to-brand-600 text-white font-bold text-base py-4 rounded-2xl transition-all shadow-lg shadow-brand-500/30 transform hover:-translate-y-1 flex justify-center items-center gap-3 disabled:opacity-75 disabled:cursor-wait">
                        <i id="btnIcon" class="fa-solid fa-paper-plane text-xl"></i> 
                        <span id="btnText">เริ่มกระบวนการปรับแต่ง & ส่งให้ทีม AI</span>
                    </button>
                </div>
            </div>

        </div>
    </main>

    <!-- Modals (Settings & Team) -> Identical Structure to previous version but included for completeness -->
    <!-- Settings Modal -->
    <div id="settingsModal" class="modal-overlay fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm">
        <div class="modal-content bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden relative border border-slate-100">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
