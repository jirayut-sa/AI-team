                <button onclick="toggleModal('settingsModal')" class="w-8 h-8 rounded-full hover:bg-slate-200 text-slate-500 transition flex items-center justify-center"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="p-6 space-y-5">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Personal Access Token</label>
                    <div class="relative">
                        <i class="fa-solid fa-key absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input type="password" id="ghToken" class="w-full bg-white border border-slate-300 rounded-xl py-3 pl-10 pr-4 focus:border-brand-500 focus:outline-none transition" placeholder="ghp_xxxxxxxx...">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Target Repository</label>
                    <div class="relative">
                        <i class="fa-solid fa-book-bookmark absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        <input type="text" id="ghRepo" class="w-full bg-white border border-slate-300 rounded-xl py-3 pl-10 pr-4 focus:border-brand-500 focus:outline-none transition" placeholder="username/repo-name">
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-100">
                <button onclick="saveSettings()" class="w-full bg-dark hover:bg-slate-800 text-white font-bold py-3 rounded-xl transition shadow-md">บันทึกข้อมูล</button>
            </div>
        </div>
    </div>

    <!-- Team Modal -->
    <div id="teamModal" class="modal-overlay fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm">
        <!-- Re-using the same structure as previous code for team management -->
        <div class="modal-content bg-white rounded-3xl shadow-2xl w-full max-w-3xl overflow-hidden flex flex-col max-h-[85vh] border border-slate-100">
            <div class="px-6 py-5 flex justify-between items-center bg-dark text-white">
                <h2 class="text-lg font-bold flex items-center gap-2"><i class="fa-solid fa-address-card text-brand-400"></i> จัดการพนักงาน AI (Model Registry)</h2>
                <button onclick="toggleModal('teamModal')" class="w-8 h-8 rounded-full hover:bg-white/20 text-white transition flex items-center justify-center"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="flex-1 overflow-y-auto p-6 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4 border-b pb-2">รายชื่อ Models ทั้งหมดในทีม</h3>
                <div id="teamList" class="grid grid-cols-1 sm:grid-cols-2 gap-3"></div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="fixed bottom-5 left-1/2 transform -translate-x-1/2 translate-y-20 opacity-0 transition-all duration-300 z-[60] flex items-center gap-3 px-6 py-3.5 rounded-full shadow-2xl font-bold text-sm min-w-[300px] max-w-md w-max">
        <i id="toastIcon" class="text-xl"></i>
        <span id="toastMessage" class="flex-1"></span>
    </div>

    <!-- ==============================================
         JAVASCRIPT LOGIC
         ============================================== -->
    <script>
        // Data Configuration
        const tasks = [
            { id: 't1', icon: 'bx-search-alt', name: 'หาข้อมูล/วิจัย', category: 'research', requires: { lead: 'research', reviewer: 'content' } },
            { id: 't2', icon: 'bx-image-alt', name: 'สร้างภาพ', category: 'creative', requires: { lead: 'creative', reviewer: 'content' } },
            { id: 't3', icon: 'bx-video-recording', name: 'สร้างวิดีโอ', category: 'creative', requires: { lead: 'creative', reviewer: 'review' } },
            { id: 't4', icon: 'bx-slideshow', name: 'สร้างสไลด์', category: 'creative', requires: { lead: 'content', reviewer: 'creative' } },
            { id: 't5', icon: 'bx-file-find', name: 'สรุปงาน/ประชุม', category: 'content', requires: { lead: 'research', reviewer: 'content' } },
            { id: 't6', icon: 'bx-text', name: 'แปลภาษา', category: 'content', requires: { lead: 'content', reviewer: 'review' } },
            { id: 't7', icon: 'bxs-file-pdf', name: 'แปลง/สรุป PDF', category: 'utility', requires: { lead: 'utility', reviewer: 'research' } },
            { id: 't8', icon: 'bx-network-chart', name: 'ทำ Mind Map', category: 'utility', requires: { lead: 'utility', reviewer: 'content' } },
            { id: 't9', icon: 'bx-code-block', name: 'เขียนโปรแกรม', category: 'code', requires: { lead: 'code', reviewer: 'review' } },
            { id: 't10', icon: 'bx-bug-alt', name: 'แก้บั๊ก / ตรวจโค้ด', category: 'code', requires: { lead: 'review', reviewer: 'code' } },
            { id: 't11', icon: 'bx-pen', name: 'แต่งบทความ', category: 'content', requires: { lead: 'content', reviewer: 'research' } },
            { id: 't12', icon: 'bx-data', name: 'วิเคราะห์ Data', category: 'research', requires: { lead: 'research', reviewer: 'code' } },
            { id: 't13', icon: 'bx-line-chart', name: 'แผนการตลาด', category: 'research', requires: { lead: 'research', reviewer: 'creative' } },
            { id: 't14', icon: 'bx-envelope', name: 'ร่างอีเมล', category: 'content', requires: { lead: 'content', reviewer: 'review' } },
            { id: 't15', icon: 'bx-shield-quarter', name: 'ตรวจ Security', category: 'code', requires: { lead: 'review', reviewer: 'code' } }
        ];

        const defaultAgents = [
            { id: 'a1', name: 'Perplexity', modelId: 'perplexity-online', skill: 'research', role: 'Data Researcher', isDefault: true },
            { id: 'a2', name: 'Midjourney / DALL-E', modelId: 'creative-engine-v1', skill: 'creative', role: 'Art & Visual Director', isDefault: true },
            { id: 'a3', name: 'Claude 3.5 Sonnet', modelId: 'claude-3-5-sonnet', skill: 'utility', role: 'Format & Structurer', isDefault: true },
            { id: 'a4', name: 'DeepSeek Coder', modelId: 'deepseek-coder-v2', skill: 'code', role: 'Lead Developer', isDefault: true },
            { id: 'a5', name: 'Llama 3 (70B)', modelId: 'meta-llama-3-70b', skill: 'review', role: 'Senior QA / Validator', isDefault: true },
            { id: 'a6', name: 'GPT-4o', modelId: 'gpt-4o', skill: 'content', role: 'Creative Copywriter', isDefault: true }
        ];

        let aiTeam = [];
        let state = { task: null, team: { lead: null, reviewer: null }, refinedPrompt: '' };

        window.onload = () => {
            document.getElementById('ghToken').value = localStorage.getItem('aiOffice_token') || '';
            document.getElementById('ghRepo').value = localStorage.getItem('aiOffice_repo') || '';
            aiTeam = JSON.parse(localStorage.getItem('aiOffice_team')) || [...defaultAgents];
            renderTasks();
            renderTeamList();
        };

        function renderTasks() {
            const grid = document.getElementById('taskGrid');
            tasks.forEach(task => {
                const btn = document.createElement('button');
                btn.className = 'task-card flex flex-col items-center justify-center p-3 bg-white border border-slate-200 rounded-2xl cursor-pointer gap-2 text-center h-24 sm:h-28';
                btn.onclick = () => selectTask(task.id, btn);
                btn.innerHTML = `
                    <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center mb-0.5 group-hover:bg-brand-100 transition-colors">
                        <i class='bx ${task.icon} text-2xl text-slate-600 group-hover:text-brand-600'></i>
                    </div>
                    <span class="text-xs font-bold text-slate-700 leading-tight px-1">${task.name}</span>
                `;
                grid.appendChild(btn);
            });
        }

        function renderTeamList() {
            const list = document.getElementById('teamList');
            list.innerHTML = '';
            aiTeam.forEach(ai => {
                const iconMap = { code: 'bx-code', content: 'bx-pen', research: 'bx-search', review: 'bx-check-shield', creative: 'bx-palette', utility: 'bx-cog' };
                list.innerHTML += `
                    <div class="flex items-center justify-between bg-white p-3 rounded-xl border border-slate-200">
                        <div class="flex items-center gap-3 w-[85%]">
                            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-500 flex items-center justify-center shrink-0">
                                <i class='bx ${iconMap[ai.skill] || 'bx-bot'}'></i>
                            </div>
                            <div class="truncate">
                                <p class="text-sm font-bold text-slate-800 leading-tight truncate">${ai.name}</p>
                                <p class="text-[10px] text-slate-500 font-mono truncate">${ai.modelId} • ${ai.skill}</p>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        function selectTask(taskId, btnElement) {
            document.querySelectorAll('.task-card').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
            state.task = tasks.find(t => t.id === taskId);
            
            // Auto Assembly Team
            const leads = aiTeam.filter(a => a.skill === state.task.requires.lead);
            state.team.lead = leads.length > 0 ? leads[0] : aiTeam[0];

            let reviewers = aiTeam.filter(a => a.skill === state.task.requires.reviewer && a.id !== state.team.lead.id);
            if (reviewers.length === 0) reviewers = aiTeam.filter(a => a.id !== state.team.lead.id);
            state.team.reviewer = reviewers.length > 0 ? reviewers[0] : aiTeam[1] || aiTeam[0];

            document.getElementById('leadName').innerText = state.team.lead.name;
            document.getElementById('leadRole').innerText = `[${state.team.lead.skill.toUpperCase()}] ${state.team.lead.modelId}`;
            document.getElementById('reviewerName').innerText = state.team.reviewer.name;
            document.getElementById('reviewerRole').innerText = `[${state.team.reviewer.skill.toUpperCase()}] ${state.team.reviewer.modelId}`;
            document.getElementById('teamAssignmentPanel').classList.remove('hidden');
            
            // Reset Refined area
            document.getElementById('refinedPrompt').value = '';
            state.refinedPrompt = '';
        }

        // --- Core Auto-Pipeline ---
        async function processAndSend() {
            const raw = document.getElementById('promptInput').value.trim();
            const token = document.getElementById('ghToken').value.trim();
            const repo = document.getElementById('ghRepo').value.trim();

            if (!state.task) return showToast('กรุณาเลือกประเภทงานก่อนครับ', 'error');
            if (!raw) return showToast('กรุณาพิมพ์บรีฟงานเบื้องต้นก่อนครับ', 'error');
            if (!token || !repo) {
                showToast('โปรดตั้งค่า GitHub Config ให้เรียบร้อยก่อน', 'error');
                return toggleModal('settingsModal');
            }

            const btn = document.getElementById('submitBtn');
            const icon = document.getElementById('btnIcon');
            const text = document.getElementById('btnText');
            const loader = document.getElementById('promptLoader');
            const statusText = document.getElementById('loaderStatusText');

            // 1. Enter Processing State
            btn.disabled = true;
            icon.className = 'fa-solid fa-wand-magic-sparkles fa-shake text-xl text-amber-300';
            text.innerText = 'กำลังสร้างคำสั่งระดับ Pro...';
            loader.classList.add('active');

            // 2. Generate Professional Prompt Logic
            await new Promise(r => setTimeout(r, 1000)); // Simulate thinking
            statusText.innerText = 'กำลังกำหนด Persona และกรอบการทำงาน...';
            
            const proPrompt = generateProfessionalPrompt(raw, state.task, state.team);
            state.refinedPrompt = proPrompt;
            document.getElementById('refinedPrompt').value = proPrompt;

            await new Promise(r => setTimeout(r, 1000)); // Simulate typing/formatting
            statusText.innerText = 'กำลังเชื่อมต่อระบบเพื่อส่งมอบงาน (GitHub)...';
            icon.className = 'fa-solid fa-circle-notch fa-spin text-xl';
            text.innerText = 'กำลังส่งข้อมูลไปยังระบบ...';

            // 3. Send to GitHub
            await sendToGitHubAPI(proPrompt, raw, token, repo);

            // 4. Reset UI
            loader.classList.remove('active');
            btn.disabled = false;
            icon.className = 'fa-solid fa-paper-plane text-xl';
            text.innerText = 'เริ่มกระบวนการปรับแต่ง & ส่งให้ทีม AI';
        }

        function generateProfessionalPrompt(rawBrief, task, team) {
            let p = `=================================================================\n`;
            p += `SYSTEM ROLE: 👑 ${team.lead.role} | Expert Level Execution\n`;
            p += `=================================================================\n\n`;

            p += `[🎯 PRIMARY OBJECTIVE]\nYou are tasked with delivering a world-class output for the following request. You must operate at the absolute highest standard of a professional ${task.name} expert.\n\n`;

            p += `[📖 ORIGINAL USER BRIEF]\n"${rawBrief}"\n\n`;

            p += `[⚙️ QUALITY STANDARDS & STRICT CONSTRAINTS]\n`;
            if (task.category === 'code') {
                p += `- Architecture: Ensure clean, scalable, modular, and DRY code.\n`;
                p += `- Best Practices: Follow industry design patterns and robust error handling.\n`;
                p += `- Output: Provide ONLY functional, production-ready code blocks (\`\`\`). No conversational filler.\n`;
            } else if (task.category === 'creative') {
                p += `- Vision: Interpret the brief with high creativity, originality, and structure.\n`;
                p += `- Detail: Specify composition, styling, mood, or narrative pacing in exact detail.\n`;
                p += `- Output: Deliver highly descriptive prompts, storyboards, or structured slide layouts.\n`;
            } else if (task.category === 'research' || task.category === 'utility') {
                p += `- Accuracy: Cross-reference data mentally to ensure 100% logical and factual consistency.\n`;
                p += `- Structure: Use MECE (Mutually Exclusive, Collectively Exhaustive) frameworks.\n`;
                p += `- Output: Present findings in a highly readable format (e.g., Markdown tables, hierarchies, JSON/XML if requested).\n`;
            } else {
                p += `- Tone: Maintain a highly professional, authoritative, yet engaging tone.\n`;
                p += `- Structure: Use logical pacing, compelling hooks, and clear section breaks.\n`;
                p += `- Polish: Ensure flawless grammar, nuanced vocabulary, and readability.\n`;
            }

            p += `\n[📦 EXPECTED OUTPUT FORMAT]\nProvide the final output beautifully formatted in standard Markdown (unless code/JSON is specifically required).\n\n`;

            p += `[🤝 COLLABORATION HANDOFF]\nEnd your response with a brief <Review_Notes> section addressed to your QA partner, ${team.reviewer.name} (${team.reviewer.modelId}). Highlight specific areas or assumptions they should verify in the next step.\n`;

            return p;
        }

        async function sendToGitHubAPI(proPrompt, rawBrief, token, repo) {
            const issueTitle = `[TASK] ${state.task.name} - ${rawBrief.substring(0, 30)}...`;
            const issueBody = `
<!-- AI_OFFICE_HUB_PAYLOAD 
{
  "task_category": "${state.task.category}",
  "lead_model": "${state.team.lead.modelId}",
  "reviewer_model": "${state.team.reviewer.modelId}"
}
-->
## 📋 Task Specifications
- **Type:** ${state.task.name}
- **Lead Agent:** \`${state.team.lead.modelId}\`
- **Review Agent:** \`${state.team.reviewer.modelId}\`

---

## 🚀 Optimized System Prompt
\`\`\`text
${proPrompt}
\`\`\`

---
*Generated via AI Auto-Prompt Engineer*
            `.trim();

            try {
                const response = await fetch(`https://api.github.com/repos/${repo}/issues`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Accept': 'application/vnd.github.v3+json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: issueTitle,
                        body: issueBody,
                        labels: ['ai-task', 'automated', state.task.category]
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    showToast(`มอบหมายงานสำเร็จ! (Issue #${data.number})`, 'success');
                    document.getElementById('promptInput').value = '';
                    setTimeout(() => window.open(data.html_url, '_blank'), 1500);
                } else {
                    const err = await response.json();
                    showToast(`เกิดข้อผิดพลาด: ${err.message || response.statusText}`, 'error');
                }
            } catch (error) {
                showToast(`การเชื่อมต่อล้มเหลว โปรดตรวจสอบ Token/Repo`, 'error');
            }
        }

        function toggleModal(id) { document.getElementById(id).classList.toggle('show'); }
        function saveSettings() {
            localStorage.setItem('aiOffice_token', document.getElementById('ghToken').value.trim());
            localStorage.setItem('aiOffice_repo', document.getElementById('ghRepo').value.trim());
            toggleModal('settingsModal');
            showToast('บันทึกข้อมูลสำเร็จ', 'success');
        }

        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const text = document.getElementById('toastMessage');

            text.innerText = message;
            toast.className = `fixed bottom-5 left-1/2 transform -translate-x-1/2 z-[60] flex items-center gap-3 px-6 py-3.5 rounded-full shadow-2xl font-bold text-sm min-w-[300px] max-w-md w-max transition-all duration-300 ${
                type === 'success' ? 'bg-emerald-500 text-white' : type === 'error' ? 'bg-rose-500 text-white' : 'bg-dark text-white'
            }`;
            icon.className = type === 'success' ? 'fa-solid fa-circle-check text-white' : type === 'error' ? 'fa-solid fa-triangle-exclamation text-white' : 'fa-solid fa-bell text-brand-400';

            toast.style.opacity = '1'; toast.style.transform = 'translate(-50%, 0)';
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translate(-50%, 20px)'; }, 4000);
        }
    </script>
</body>
</html>

